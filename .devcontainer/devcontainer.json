{
  "name": "Aether Flow",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "bun install && bun --bun run prisma generate",
  "containerEnv": {
    "INNGEST_DEV": "1"
  },
  "remoteEnv": {
    "BETTER_AUTH_URL": "https://${localEnv:CODESPACE_NAME}-3000.${localEnv:GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}"
  },
  "forwardPorts": [3000, 8288],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "openBrowser"
    },
    "8288": {
      "label": "Inngest Dev Server",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "oxc.oxc-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  }
}
